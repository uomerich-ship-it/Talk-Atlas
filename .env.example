# DeepL Translation API (free: 500k chars/month)
# Sign up at: https://www.deepl.com/pro-api
VITE_DEEPL_API_KEY=your_deepl_key_here

# OpenAI API key (for translation, phrasebook, cultural tips, image translation, Whisper)
# Sign up at: https://platform.openai.com
VITE_OPENAI_API_KEY=your_openai_key_here

# Google Places API key (for Wayfinder panel)
# Enable "Places API" and "Maps JavaScript API" at console.cloud.google.com
# Free tier = $200 credit/month (~28,000 place searches free)
VITE_GOOGLE_PLACES_KEY=your_google_places_key_here

# RevenueCat - in-app purchases (free until $2500/month revenue)
# Sign up at: https://app.revenuecat.com
VITE_RC_API_KEY_IOS=appl_xxxxxxxxxxxx
VITE_RC_API_KEY_ANDROID=goog_xxxxxxxxxxxx
